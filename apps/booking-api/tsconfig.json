{
  "compilerOptions": {
    "target": "esnext",
    "lib": [
      "ES2024"
    ],
    "module": "nodenext",
    "rootDir": "./",
    "moduleResolution": "nodenext",
    "paths": {
      "*": ["./src/*"]
    },
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "noErrorTruncation": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"]
}
